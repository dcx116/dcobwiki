views:
  - type: table
    name: 表格
    filters:
      and:
        - daitype == "model"
    order:
      - file.name
      - source
      - file.folder
      - daibasemodel
      - daimodeltype
      - daitype
    sort:
      - property: daitype
        direction: ASC
      - property: daibasemodel
        direction: ASC
